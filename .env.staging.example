# ============================================================
# Staging 환경 변수 템플릿
# Railway staging 환경에 아래 변수들을 그대로 복사해서 설정하세요.
# 실제 값은 Railway 콘솔 > staging 환경 > Variables에 입력합니다.
# ============================================================

# Server
PORT=3000
NODE_ENV=staging
APP_ENV=staging
BASE_URL=https://stg-여기에-railway-도메인.up.railway.app

# Database (staging 전용 Railway MySQL 인스턴스 - production과 완전히 분리)
# Railway staging 환경에서 MySQL 플러그인 추가 시 자동으로 MYSQL_* 변수가 주입됩니다.
MYSQL_HOST=staging-mysql-host
MYSQL_PORT=3306
MYSQL_USER=staging-db-user
MYSQL_PASSWORD=staging-db-password
MYSQL_DATABASE=railway

# JWT (staging 전용 시크릿 - production과 반드시 다르게 설정)
JWT_SECRET=staging_jwt_secret_change_this
JWT_EXPIRES_IN=7d

# Admin
ADMIN_SECRET=staging_admin_secret_change_this

# BGG API
BGG_API_TOKEN=

# BGG 크론 비활성화 (staging에서는 true)
DISABLE_BGG_CRON=true

# FCM 푸시 알림
# staging에서는 비워두면 실제 알림을 보내지 않고 콘솔 출력으로 대체됩니다.
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Papago 번역 (선택)
PAPAGO_CLIENT_ID=
PAPAGO_CLIENT_SECRET=
