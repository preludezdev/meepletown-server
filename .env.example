# Server
PORT=3000
NODE_ENV=development

# Database (카페24 MySQL 호스팅)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=meepleon_db

# JWT
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Admin (어드민 페이지 접근용 시크릿 키 - Railway 환경변수에도 동일하게 설정 필요)
ADMIN_SECRET=your_admin_secret_change_this
