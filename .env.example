# Server
PORT=3000
NODE_ENV=development
APP_ENV=development           # production | staging | development
BASE_URL=http://localhost:3000

# Database (Railway MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=meepleon_db

# JWT
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Admin (어드민 페이지 접근용 시크릿 키)
ADMIN_SECRET=your_admin_secret_change_this

# BGG API (선택)
BGG_API_TOKEN=

# BGG 크론 비활성화 (staging/development에서 true로 설정)
DISABLE_BGG_CRON=true

# FCM 푸시 알림 (선택 - production에서만 실제 발송)
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Papago 번역 (선택)
PAPAGO_CLIENT_ID=
PAPAGO_CLIENT_SECRET=
